# DataSaaS Backend Configuration
# Copy this file to .env and update values for your environment

# JWT Configuration
JWT_SECRET_KEY=change-this-in-production-please-use-a-strong-32plus-char-secret
JWT_EXPIRE_HOURS=2

# Authentication Rate Limiting
AUTH_MAX_LOGIN_ATTEMPTS=5
AUTH_LOGIN_WINDOW_MINUTES=15
AUTH_MAX_REGISTER_ATTEMPTS=5
AUTH_REGISTER_WINDOW_MINUTES=30
AUTH_MAX_RESET_ATTEMPTS=5
AUTH_RESET_WINDOW_MINUTES=30

# Email Verification & Password Reset
AUTH_VERIFY_TOKEN_EXPIRE_MINUTES=1440
AUTH_RESET_TOKEN_EXPIRE_MINUTES=30

# Database (SQLite path)
AUTH_DB_PATH=./auth.sqlite3

# Email / SMTP Configuration
# Leave SMTP_HOST empty or comment out to use simulated email (logs to console)
# For production, configure a real SMTP provider
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password-or-token
SMTP_FROM=noreply@datasaas.local
FEEDBACK_RECIPIENT_EMAIL=vikashpandit712@gmail.com

# Application Environment
APP_ENV=development
APP_BASE_URL=http://localhost:5173

# Logging
LOG_LEVEL=INFO
