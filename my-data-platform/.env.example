# DataSaaS Pro Platform Configuration Template
# Copy this file to .env and adjust variables to suit your deployment environment.

# ==========================================
# 🔐 Security & Authentication Settings
# ==========================================
# Secret key used for signing JWT tokens (use a strong 32+ character key)
JWT_SECRET_KEY=change-this-in-production-please-use-a-strong-32plus-char-secret
JWT_EXPIRE_HOURS=2

# Admin User Seed Configuration (auto-creates admin account on startup if both are set)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=strong-admin-password-here
ADMIN_EMAIL=admin@datasaas.local

# Rate Limiting parameters
AUTH_MAX_LOGIN_ATTEMPTS=5
AUTH_LOGIN_WINDOW_MINUTES=15
AUTH_MAX_REGISTER_ATTEMPTS=5
AUTH_REGISTER_WINDOW_MINUTES=30

# ==========================================
# 🗄️ Database Configurations
# ==========================================
# Postgres configuration used in Docker setups
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=datasaas_db

# Connection string for SQLAlchemy (defaults to SQLite locally, Postgres in Docker)
# Local SQLite example: sqlite:///./auth.sqlite3
DATABASE_URL=postgresql://postgres:password@db:5432/datasaas_db

# Path to SQLite database storing user authentication and security tables
AUTH_DB_PATH=/app/data/auth.sqlite3

# ==========================================
# 🚀 Host & Environment Settings
# ==========================================
APP_ENV=production
APP_BASE_URL=http://localhost

# Log Level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ==========================================
# 📧 SMTP Configuration (Email Templates)
# ==========================================
# Leave SMTP_HOST empty or comment out to log email templates to stdout (simulated delivery)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@datasaas.local
FEEDBACK_RECIPIENT_EMAIL=feedback@datasaas.local
